# Files excluded from HuggingFace Space Docker build
# Keep this lean — only block dev/training files the server doesn't need

# Python cache
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/

# Dev / test tools
.venv/
venv/
.pytest_cache/
test_features_smoke.py
uv.lock
audit.py

# Training-only scripts (not needed by the server at runtime)
train_data_centric.py
train_colab.ipynb
eval_data_centric.py
sft_generator.py
inference.py
hf_job_train.py
submit_job.py
plot_rewards.py

# Generated training artefacts
sft_data.jsonl
generations.jsonl
training_log.json
logs/
sft-checkpoint/
data-centric-checkpoints/
data-centric-adapter/
data-centric-merged/

# Hackathon PDFs and notes (use URLs instead)
*.pdf
BLOG.md

# Git
.git/
.gitignore
